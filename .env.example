# ═══════════════════════════════════════════════════════════
# Supreme Gaming Engine — Production Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to git
# ═══════════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────────────────────────────
# Neon PostgreSQL — use the POOLED connection string for production
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require&connect_timeout=60&pool_timeout=60"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET="REPLACE_WITH_64_CHAR_RANDOM_STRING"

# NextAuth (if used)
NEXTAUTH_SECRET="REPLACE_WITH_RANDOM_STRING"
NEXTAUTH_URL="https://yourdomain.com"

# ── Payments ──────────────────────────────────────────────────────────────────
# SMS Gateway secret — must match what's set in the Android SMS app
SMS_WEBHOOK_SECRET="REPLACE_WITH_STRONG_SECRET"

# Webhook secret for payment gateway
WEBHOOK_SECRET="REPLACE_WITH_STRONG_SECRET"

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_SECRET="REPLACE_WITH_STRONG_SECRET"
DUMMY_USER_ID="dummy-house-account"

# ── Public (safe to expose to browser) ───────────────────────────────────────
NEXT_PUBLIC_SITE_NAME="Supreme Gaming Engine"
NEXT_PUBLIC_SITE_URL="https://yourdomain.com"

# ── Optional: Error monitoring ────────────────────────────────────────────────
# Sign up free at sentry.io
# SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"

# ── Optional: SMS/OTP ─────────────────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE=
